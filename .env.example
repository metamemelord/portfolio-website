# ============================================================================
# PORTFOLIO WEBSITE - DOCKER COMPOSE ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in your actual values
# 
# REQUIRED variables will cause the application to fail if missing
# OPTIONAL variables have sensible defaults
# ============================================================================

# ============================================================================
# REQUIRED CONFIGURATION
# ============================================================================

# Basic Authentication
# Format: username:password (will be Base64 encoded for HTTP Basic Auth)
# Example: admin:MySecurePassword123
APP_AUTH=admin:password

# MongoDB Connection String
# Format: mongodb://[username:password@]host[:port]/[database][?options]
# If using MongoDB in Docker: mongodb://admin:password123@mongodb:27017/portfolio?authSource=admin
MONGO_URI=mongodb://admin:password123@mongodb:27017/portfolio?authSource=admin
MONGO_PASSWORD=password123

# ============================================================================
# MICROSOFT 365 EMAIL INTEGRATION (Required if you want email functionality)
# ============================================================================
# Get these from Azure AD App Registration
# https://portal.azure.com/ -> Azure AD -> App registrations

# Azure AD Tenant ID (Directory ID)
MS_TENANT_ID=your-tenant-id-here

# Azure AD Application (Client) ID
MS_CLIENT_ID=your-app-client-id-here

# Azure AD Client Secret (NOT the certificate thumbprint)
MS_EMAIL_KEY=your-client-secret-here

# Microsoft Graph User ID (the ID of the user account that will send emails)
# Run: GET https://graph.microsoft.com/v1.0/me/id
MS_GRAPH_SELF_USER_ID=your-user-id-here

# Sender email address for contact form emails
SELF_EMAIL=noreply@gaurav.dev

# ============================================================================
# SERVER CONFIGURATION (Optional - have sensible defaults)
# ============================================================================

# Port to run the server on (default: 3000)
PORT=3000

# Gin framework mode: "release" for production, leave empty for debug
# Set to "release" to skip npm rebuild on startup
GIN_MODE=release

# Environment mode: "release" for production, leave empty for development
# Set to "release" to skip npm rebuild on startup
ENV=release

# ============================================================================
# KEEP-ALIVE CONFIGURATION (Optional)
# ============================================================================
# Useful for preventing Heroku apps from sleeping

# Enable periodic health check requests (default: true)
# Set to "false" or "0" to disable
KEEP_ALIVE_CRON=false

# Base URL to send keep-alive requests to (must have /health endpoint)
# Example for production: https://yourdomain.com
KEEP_ALIVE_BASE_URL=http://localhost:3000

# ============================================================================
# TLS/HTTPS CONFIGURATION (Optional)
# ============================================================================
# Only needed if you want to run with HTTPS instead of HTTP

# Enable TLS (default: false)
# Set to "true" or "1" to enable
TLS_ENABLED=false

# Path to TLS certificate file (required if TLS_ENABLED=true)
# Example: /etc/portfolio/certs/cert.pem
TLS_CERT_PATH=

# Path to TLS private key file (required if TLS_ENABLED=true)
# Example: /etc/portfolio/certs/key.pem
TLS_KEY_PATH=

# ============================================================================
# EXTERNAL SERVICE DEPENDENCIES (Automatic)
# ============================================================================
# The application automatically fetches from these (non-critical if unavailable):
#
# - GitHub API: https://api.github.com/users/metamemelord/repos (every 2 hours)
# - WordPress API: https://public-api.wordpress.com/rest/v1.1/sites/metamemelord.wordpress.com/posts/ (every 2 hours)
#
# These are public API calls and require no configuration
# ============================================================================
